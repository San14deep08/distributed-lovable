# Copy to .env.prod on the EC2 host and fill in real values. NEVER commit .env.prod.

# ECR registry, e.g. 123456789012.dkr.ecr.ap-south-1.amazonaws.com
ECR_REGISTRY=

# RDS PostgreSQL
DB_HOST=
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=

# Generated secret for JWT signing (e.g. `openssl rand -hex 48`)
JWT_SECRET=

# MinIO credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=

# External APIs (optional until needed)
AI_API_KEY=
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
